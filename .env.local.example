# ── HER Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── AI Provider ─────────────────────────────────────────────
# Which provider to use: "gemini" | "nvidia"
HER_PROVIDER=nvidia

# ── Google Gemini ───────────────────────────────────────────
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── NVIDIA NIM API Keys ─────────────────────────────────────
# Get your API keys at: https://build.nvidia.com/
# Each image model can use its own dedicated key.
# If a model-specific key is not set, NVIDIA_IMAGE_API_KEY is used as fallback.

# Chat (Mistral Large 3)
NVIDIA_CHAT_API_KEY=your_chat_key_here

# Image Generation — per-model keys (optional, takes priority over shared key)
NVIDIA_SD3_MEDIUM_API_KEY=your_sd3_key_here
NVIDIA_FLUX2_KLEIN_API_KEY=your_flux2_klein_key_here
NVIDIA_FLUX1_DEV_API_KEY=your_flux1_dev_key_here
NVIDIA_FLUX1_KONTEXT_API_KEY=your_flux1_kontext_key_here

# Image Generation — shared fallback (used if model-specific key is missing)
NVIDIA_IMAGE_API_KEY=your_image_key_here

# Vision / Image Understanding (Gemma 3 27B)
NVIDIA_VISION_API_KEY=your_vision_key_here

# ── Supabase (Public Frontend Keys) ────────────────────────
# Project URL: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Anon/Public key: Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
